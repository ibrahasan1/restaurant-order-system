{
  "name": "restaurant-order-system",
  "version": "1.0.0",
  "description": "Internes Echtzeit-Bestellsystem für Restaurants",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "start:prod": "pm2 start ecosystem.config.js",
    "stop:prod": "pm2 stop restaurant-api",
    "restart:prod": "pm2 restart restaurant-api",
    "logs": "pm2 logs restaurant-api",
    "db:init": "node server/migrations/001_initial.js",
    "db:seed": "node server/migrations/002_seed.js",
    "db:backup": "bash scripts/backup.sh",
    "test": "jest --config jest.config.js",
    "lint": "eslint server/ client/src/"
  },
  "dependencies": {
    "better-sqlite3": "^11.6.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "eslint": "^9.14.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
