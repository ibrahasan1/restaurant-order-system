# ===================================
# Restaurant Order System - Konfiguration
# ===================================
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Datenbank
DB_PATH=./data/restaurant.sqlite

# Socket.IO
SOCKET_PING_INTERVAL=10000
SOCKET_PING_TIMEOUT=5000

# Sicherheit
CORS_ORIGIN=*
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# Backup
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30

# Restaurant-Konfiguration
RESTAURANT_NAME=Mein Restaurant
TABLE_COUNT=20
CURRENCY=EUR
TIMEZONE=Europe/Berlin
